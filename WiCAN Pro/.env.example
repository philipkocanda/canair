# WiCAN Pro credentials
# Copy this file to .env and fill in your actual values.

# Primary WiFi station
WICAN_STA_PASS=your-wifi-password

# WiCAN device Access Point
WICAN_AP_PASS=your-ap-password

# Bluetooth LE pairing PIN
WICAN_BLE_PASS=000000

# Battery alert WiFi
WICAN_BATT_ALERT_PASS=your-batt-alert-wifi-pass

# Battery alert MQTT
WICAN_BATT_MQTT_USER=your-batt-mqtt-user
WICAN_BATT_MQTT_PASS=your-batt-mqtt-pass

# Main MQTT broker
WICAN_MQTT_USER=your-mqtt-user
WICAN_MQTT_PASS=your-mqtt-password

# WiFi fallback networks
WICAN_FALLBACK_IPHONE_PHILIP_PASS=your-iphone-hotspot-pass
WICAN_FALLBACK_BABYFOON_PASS=your-babyfoon-pass
WICAN_FALLBACK_RUSTY_IOT_PASS=your-rusty-iot-pass
WICAN_FALLBACK_IPHONE_EVA_PASS=your-iphone-eva-pass
WICAN_FALLBACK_HOI_PASS=your-hoi-pass
